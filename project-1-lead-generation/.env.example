# ============================================================
# Project 1 — Lead Generation + Outreach
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# AI model (no real API key required — responses are simulated for demo)
CLAUDE_MODEL=claude-opus-4-8

# PostgreSQL (matches the postgres service in docker-compose.yml)
DATABASE_URL=postgresql://n8n:n8n@postgres:5432/leads

# n8n webhook (simulated — no live n8n instance required for tests)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/leads

# Logging
LOG_LEVEL=INFO

# Pipeline behaviour
BATCH_SIZE=10

# Lead scoring thresholds
MIN_SCORE_THRESHOLD=4
HOT_THRESHOLD=8
WARM_THRESHOLD=5
