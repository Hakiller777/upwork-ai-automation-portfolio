# ============================================================
# .env.example — AI Automation Portfolio
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# All values here are placeholders only — no real secrets.
# ============================================================


# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------

# Database name (used by both n8n and Python apps)
POSTGRES_DB=portfolio_db

# Database superuser credentials
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=change_me_strong_password

# Host port exposed on your machine (default: 5432)
# Change if 5432 is already taken locally
POSTGRES_PORT=5432


# ------------------------------------------------------------
# n8n — self-hosted workflow engine
# ------------------------------------------------------------

# Hostname where n8n is reachable
# Local dev: localhost | Railway: your-app.up.railway.app
N8N_HOST=localhost

# Port n8n listens on (default: 5678)
N8N_PORT=5678

# Protocol: http (local) | https (Railway / production)
N8N_PROTOCOL=http

# Full public URL used for webhook callbacks
# Local: http://localhost:5678 | Railway: https://your-app.up.railway.app
N8N_WEBHOOK_URL=http://localhost:5678

# Basic auth credentials for the n8n UI
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password

# Encryption key for credentials stored in n8n (min 32 chars, random)
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_32_char_random_string_here


# ------------------------------------------------------------
# Python app
# ------------------------------------------------------------

# Constructed from the PostgreSQL vars above — no need to change
# if you keep the DB vars consistent.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://portfolio_user:change_me_strong_password@localhost:5432/portfolio_db

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ------------------------------------------------------------
# Railway deployment (fill when deploying)
# ------------------------------------------------------------

# Railway injects PORT automatically — do not set it manually
# PORT=

# On Railway, set N8N_HOST to your Railway public domain, e.g.:
# N8N_HOST=your-n8n-service.up.railway.app
# N8N_PROTOCOL=https
# N8N_WEBHOOK_URL=https://your-n8n-service.up.railway.app
