# ============================================================
# Project 3 — Document Processing / Invoicing
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Extraction backend: "mock" (default, deterministic regex, zero cost)
# or "claude" (documented production path, not wired up in this demo)
EXTRACTION_BACKEND=mock
CLAUDE_MODEL=claude-opus-4-8

# n8n webhook (simulated — no live n8n instance required for tests)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/document-processing

# Logging
LOG_LEVEL=INFO

# Storage
INCOMING_DIR=data/incoming
OUTPUT_DIR=data/output
REGISTRY_DB_PATH=data/registry.db

# Report generation: "json" (default) or "pdf"
REPORT_FORMAT=json

# Classification
MIN_CLASSIFICATION_CONFIDENCE=0.5
