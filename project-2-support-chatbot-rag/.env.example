# ============================================================
# Project 2 — RAG Support Chatbot
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# AI model (no real API key required — answer generation is simulated for demo)
CLAUDE_MODEL=claude-opus-4-8

# n8n webhook (simulated — no live n8n instance required for tests)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/support-query

# Logging
LOG_LEVEL=INFO

# Vector store (ChromaDB, embedded — persisted to a local/mounted directory)
CHROMA_PERSIST_DIR=data/chroma_store
COLLECTION_NAME=acmecrm_knowledge_base
KNOWLEDGE_BASE_DIR=data/knowledge_base

# Embedding vectorizer
EMBEDDING_DIM=256

# Chunking
CHUNK_SIZE=120
CHUNK_OVERLAP=20

# Retrieval
TOP_K=4
MIN_CONFIDENCE_THRESHOLD=0.15
